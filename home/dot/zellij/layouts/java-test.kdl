layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        children
        pane size=1 borderless=true {
            plugin location="zellij:status-bar"
        }
    }

    tab name="Java Test" {
        pane split_direction="vertical" {
            pane name="opencode" size="35%" command="opencode" {
                cwd "/home/dot/Projects/java-test"
            }

            pane name="nixvim" size="65%" command="nvim" {
                cwd "/home/dot/Projects/java-test"
                args "."
            }
        }
    }
}

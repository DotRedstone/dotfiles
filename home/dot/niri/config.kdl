// ---
// Warden Niri Configuration
// ---

spawn-at-startup "xwayland-satellite"
spawn-at-startup "dbus-update-activation-environment" "--systemd" "--all"
spawn-at-startup "noctalia-shell"
spawn-at-startup "sh" "-c" "sleep 1 && fcitx5 -d --replace"

// [Monitor Settings]
output "eDP-1" {
    mode "3072x1920@165.002"
    scale 1.75
}

output "HDMI-A-1" {
    mode "2560x1440@143.981"
    scale 1.0
}

// [Layout]
layout {
    gaps 14
    background-color "transparent"
    center-focused-column "never"
    default-column-width { proportion 0.5; }
    focus-ring {
        width 3
        active-color "#b4befe"
        inactive-color "#313244"
    }
}

// [Blur Settings]
blur {
    passes 2
    offset 2.5
}

// [Keybindings]
binds {
    // Basic
    Mod+Return { spawn "wezterm"; }
    Mod+W { spawn "firefox"; }
    Mod+E { spawn "nautilus"; }
    Mod+Q { close-window; }
    Mod+Shift+E { quit; }

    // Mac-style Shortcuts (Super+Key → Ctrl+Key)
    Mod+C repeat=false { spawn "niri-mac-shortcut" "copy"; }
    Mod+V repeat=false { spawn "niri-mac-shortcut" "paste"; }
    Mod+X repeat=false { spawn "niri-mac-shortcut" "cut"; }
    Mod+Z repeat=false { spawn "niri-mac-shortcut" "undo"; }
    Mod+Shift+Z repeat=false { spawn "niri-mac-shortcut" "redo"; }
    Mod+A repeat=false { spawn "niri-mac-shortcut" "select-all"; }
    Mod+S repeat=false { spawn "niri-mac-shortcut" "save"; }
    Mod+Shift+V repeat=false { spawn "niri-mac-shortcut" "paste-plain"; }

    // Media & Fn Keys
    XF86AudioRaiseVolume allow-when-locked=true { spawn "wpctl" "set-volume" "@DEFAULT_AUDIO_SINK@" "5%+"; }
    XF86AudioLowerVolume allow-when-locked=true { spawn "wpctl" "set-volume" "@DEFAULT_AUDIO_SINK@" "5%-"; }
    XF86AudioMute        allow-when-locked=true { spawn "wpctl" "set-mute" "@DEFAULT_AUDIO_SINK@" "toggle"; }
    XF86AudioMicMute     allow-when-locked=true { spawn "wpctl" "set-mute" "@DEFAULT_AUDIO_SOURCE@" "toggle"; }
    XF86MonBrightnessUp   allow-when-locked=true { spawn "brightnessctl" "set" "5%+"; }
    XF86MonBrightnessDown allow-when-locked=true { spawn "brightnessctl" "set" "5%-"; }

    // Focus
    Mod+L { focus-column-right; }
    Mod+J { focus-window-down; }
    Mod+K { focus-window-up; }

    // Movement
    Mod+Shift+L { move-column-right; }
    Mod+Shift+J { move-window-down; }
    Mod+Shift+K { move-window-up; }

    // Monitor Switching
    Mod+Ctrl+H { move-column-to-monitor-left; }
    Mod+Ctrl+L { move-column-to-monitor-right; }

    // Mouse & Scroll
    Mod+WheelScrollDown      { focus-column-right; }
    Mod+WheelScrollUp        { focus-column-left; }
    Mod+Alt+WheelScrollDown  { focus-workspace-down; }
    Mod+Alt+WheelScrollUp    { focus-workspace-up; }

    // Noctalia Integration
    Mod+Shift+S { spawn "sh" "-c" "grim -g \"$(slurp)\" - | wl-copy"; }
    Print { spawn "sh" "-c" "grim - | wl-copy"; }
    Mod+R { spawn "noctalia-shell" "ipc" "call" "launcher" "toggle"; }
    Mod+N { spawn "noctalia-shell" "ipc" "call" "notifications" "toggle"; }
    Mod+B { spawn "noctalia-shell" "ipc" "call" "plugin:clipper" "toggle"; }
    Mod+I { spawn "noctalia-shell" "ipc" "call" "controlCenter" "toggle"; }
    Mod+P { spawn "noctalia-shell" "ipc" "call" "power" "toggle"; }

    // Window Management
    Mod+F { maximize-column; }
    Mod+Shift+F { fullscreen-window; }
    Mod+Shift+C { center-column; }
    Mod+Comma  { consume-window-into-column; }
    Mod+Period { expel-window-from-column; }

    // Workspaces
    Mod+1 { focus-workspace 1; }
    Mod+2 { focus-workspace 2; }
    Mod+3 { focus-workspace 3; }
    Mod+4 { focus-workspace 4; }
    Mod+5 { focus-workspace 5; }
    Mod+6 { focus-workspace 6; }
    Mod+7 { focus-workspace 7; }
    Mod+8 { focus-workspace 8; }
    Mod+9 { focus-workspace 9; }
    Mod+0 { focus-workspace 10; }

    // Workspace Movement
    Mod+Alt+1 { spawn "niri" "msg" "action" "move-column-to-workspace" "1" "--focus" "false"; }
    Mod+Alt+2 { spawn "niri" "msg" "action" "move-column-to-workspace" "2" "--focus" "false"; }
    Mod+Alt+3 { spawn "niri" "msg" "action" "move-column-to-workspace" "3" "--focus" "false"; }
    Mod+Alt+4 { spawn "niri" "msg" "action" "move-column-to-workspace" "4" "--focus" "false"; }
    Mod+Alt+5 { spawn "niri" "msg" "action" "move-column-to-workspace" "5" "--focus" "false"; }
    Mod+Alt+6 { spawn "niri" "msg" "action" "move-column-to-workspace" "6" "--focus" "false"; }
    Mod+Alt+7 { spawn "niri" "msg" "action" "move-column-to-workspace" "7" "--focus" "false"; }
    Mod+Alt+8 { spawn "niri" "msg" "action" "move-column-to-workspace" "8" "--focus" "false"; }
    Mod+Alt+9 { spawn "niri" "msg" "action" "move-column-to-workspace" "9" "--focus" "false"; }
    Mod+Alt+0 { spawn "niri" "msg" "action" "move-column-to-workspace" "10" "--focus" "false"; }

    // Resizing
    Mod+Minus { set-column-width "-10%"; }
    Mod+Equal { set-column-width "+10%"; }
    Mod+Shift+Minus { set-window-height "-10%"; }
    Mod+Shift+Equal { set-window-height "+10%"; }
}

input {
    keyboard {
        numlock
    }

    touchpad {
        tap
        dwt
        natural-scroll
        click-method "clickfinger"
    }

    focus-follows-mouse max-scroll-amount="0%"
}

include "./noctalia.kdl"

window-rule {
    geometry-corner-radius 20
    clip-to-geometry true
    draw-border-with-background false
    opacity 0.80
    background-effect {
        blur true
        xray true
        noise 0.01
        saturation 1.1
    }
}

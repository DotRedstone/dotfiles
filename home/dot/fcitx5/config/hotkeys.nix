# ---
# Module: Fcitx5 Hotkeys
# Description: Key bindings and trigger configuration
# ---

{ ... }: {
  # Fcitx5 Hotkey settings
  hotkeys = ''
    [Hotkey]
    TriggerKeys=
    AltTriggerKeys=
    EnumerateForwardKeys=
    EnumerateBackwardKeys=
    EnumerateSkipFirstKeys=

    [Hotkey/TriggerKeys]
    0=Super+space
  '';
}

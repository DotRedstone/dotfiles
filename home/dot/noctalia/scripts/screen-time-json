#!/usr/bin/env node
// screen-time-json
// Summarize local ActivityWatch data for the Noctalia screen-time plugin.

const fs = require("fs");
const os = require("os");
const path = require("path");

const home = process.env.HOME || "/home/dot";
const cacheDir = path.join(home, ".cache", "noctalia", "screen-time");
const cacheFile = path.join(cacheDir, "summary.json");
const baseUrl = process.env.ACTIVITYWATCH_URL || "http://127.0.0.1:5600";
const friendlyAppNames = new Map([
  ["code", "VS Code"],
  ["codium", "VSCodium"],
  ["code-url-handler", "VS Code"],
  ["org.wezfurlong.wezterm", "WezTerm"],
  ["wezterm", "WezTerm"],
  ["com.mitchellh.ghostty", "Ghostty"],
  ["ghostty", "Ghostty"],
  ["kitty", "Kitty"],
  ["org.gnome.nautilus", "Files"],
  ["nautilus", "Files"],
  ["firefox", "Firefox"],
  ["librewolf", "LibreWolf"],
  ["google-chrome", "Chrome"],
  ["chromium", "Chromium"],
  ["obsidian", "Obsidian"],
  ["telegram-desktop", "Telegram"],
  ["org.telegram.desktop", "Telegram"],
  ["qq", "QQ"],
  ["wechat", "WeChat"],
  ["xwechat", "WeChat"],
  ["nvim", "Neovim"],
  ["neovide", "Neovide"],
  ["zathura", "Zathura"],
  ["org.pwmt.zathura", "Zathura"],
  ["steam", "Steam"],
  ["rustdesk", "RustDesk"],
  ["lm-studio", "LM Studio"],
  ["dev.zed.zed", "Zed"],
  ["zed", "Zed"],
  ["bilibili", "哔哩哔哩"]
]);

function parseArgs(argv) {
  const result = { mode: "day", range: "calendar", top: Number(process.env.SCREEN_TIME_TOP_APPS || 8) };
  for (let i = 0; i < argv.length; i++) {
    const arg = argv[i];
    const next = argv[i + 1];
    if (arg === "--mode" && next) {
      result.mode = next;
      i++;
    } else if (arg.startsWith("--mode=")) {
      result.mode = arg.split("=").slice(1).join("=");
    } else if (arg === "--range" && next) {
      result.range = next;
      i++;
    } else if (arg.startsWith("--range=")) {
      result.range = arg.split("=").slice(1).join("=");
    } else if (arg === "--top" && next) {
      result.top = Number(next);
      i++;
    } else if (arg.startsWith("--top=")) {
      result.top = Number(arg.split("=").slice(1).join("="));
    }
  }
  if (!["day", "week", "month"].includes(result.mode))
    result.mode = "day";
  if (!["calendar", "rolling"].includes(result.range))
    result.range = "calendar";
  if (!Number.isFinite(result.top) || result.top <= 0)
    result.top = 8;
  result.top = Math.min(50, Math.max(1, Math.round(result.top)));
  return result;
}

const options = parseArgs(process.argv.slice(2));

function localIso(date) {
  const pad = n => String(Math.trunc(Math.abs(n))).padStart(2, "0");
  const offsetMin = -date.getTimezoneOffset();
  const sign = offsetMin >= 0 ? "+" : "-";
  const hh = pad(offsetMin / 60);
  const mm = pad(offsetMin % 60);
  return `${date.getFullYear()}-${pad(date.getMonth() + 1)}-${pad(date.getDate())}T${pad(date.getHours())}:${pad(date.getMinutes())}:${pad(date.getSeconds())}${sign}${hh}:${mm}`;
}

function addSeconds(date, seconds) {
  return new Date(date.getTime() + seconds * 1000);
}

function addDays(date, days) {
  const d = new Date(date.getTime());
  d.setDate(d.getDate() + days);
  return d;
}

function startOfDay(date) {
  const d = new Date(date.getTime());
  d.setHours(0, 0, 0, 0);
  return d;
}

function startOfHour(date) {
  const d = new Date(date.getTime());
  d.setMinutes(0, 0, 0);
  return d;
}

function startOfWeek(date) {
  const d = startOfDay(date);
  const day = d.getDay();
  return addDays(d, day === 0 ? -6 : 1 - day);
}

function startOfMonth(date) {
  const d = startOfDay(date);
  d.setDate(1);
  return d;
}

function addMonths(date, months) {
  const d = new Date(date.getTime());
  d.setMonth(d.getMonth() + months, 1);
  d.setHours(0, 0, 0, 0);
  return d;
}

function daysBetween(start, end) {
  return Math.max(1, Math.ceil((end.getTime() - start.getTime()) / 86400000));
}

function makePeriod(mode, range, now = new Date()) {
  if (mode === "day" && range === "calendar") {
    const start = startOfDay(now);
    const end = now;
    const previousStart = addDays(start, -1);
    const previousEnd = start;
    return { start, end, previousStart, previousEnd, denominator: 1, previousDenominator: 1 };
  }
  if (mode === "day") {
    const end = now;
    const start = addSeconds(end, -86400);
    const previousEnd = start;
    const previousStart = addSeconds(previousEnd, -86400);
    return { start, end, previousStart, previousEnd, denominator: 1, previousDenominator: 1 };
  }
  if (mode === "week" && range === "calendar") {
    const start = startOfWeek(now);
    const end = now;
    const previousStart = addDays(start, -7);
    const previousEnd = start;
    return { start, end, previousStart, previousEnd, denominator: daysBetween(start, end), previousDenominator: 7 };
  }
  if (mode === "week") {
    const end = now;
    const start = addDays(end, -7);
    const previousEnd = start;
    const previousStart = addDays(previousEnd, -7);
    return { start, end, previousStart, previousEnd, denominator: 7, previousDenominator: 7 };
  }
  if (mode === "month" && range === "calendar") {
    const start = startOfMonth(now);
    const end = now;
    const previousStart = addMonths(start, -1);
    const previousEnd = start;
    return { start, end, previousStart, previousEnd, denominator: daysBetween(start, end), previousDenominator: daysBetween(previousStart, previousEnd) };
  }
  const end = now;
  const start = addDays(end, -30);
  const previousEnd = start;
  const previousStart = addDays(previousEnd, -30);
  return { start, end, previousStart, previousEnd, denominator: 30, previousDenominator: 30 };
}

function labelFor(mode, range) {
  const key = `${mode}:${range}`;
  return {
    "day:calendar": { title: "今日屏幕使用时长", apps: "今日应用使用情况", compare: "较昨日" },
    "day:rolling": { title: "近24小时屏幕使用时长", apps: "近24小时应用使用情况", compare: "较前24小时" },
    "week:calendar": { title: "本周屏幕使用时长", apps: "本周应用使用情况", compare: "较上周平均" },
    "week:rolling": { title: "近7天屏幕使用时长", apps: "近7天应用使用情况", compare: "较前7天平均" },
    "month:calendar": { title: "本月屏幕使用时长", apps: "本月应用使用情况", compare: "较上月平均" },
    "month:rolling": { title: "近30天屏幕使用时长", apps: "近30天应用使用情况", compare: "较前30天平均" }
  }[key];
}

function makeBins(mode, range, period, now = new Date()) {
  const bins = [];
  if (mode === "day") {
    const first = range === "calendar" ? startOfDay(now) : startOfHour(addSeconds(now, -23 * 3600));
    for (let i = 0; i < 24; i++) {
      const start = addSeconds(first, i * 3600);
      bins.push({ label: `${String(start.getHours()).padStart(2, "0")}:00`, start, end: addSeconds(start, 3600), seconds: 0 });
    }
    return bins;
  }

  if (mode === "week") {
    const first = range === "calendar" ? startOfWeek(now) : startOfDay(addDays(now, -6));
    for (let i = 0; i < 7; i++) {
      const start = addDays(first, i);
      bins.push({ label: String(start.getDate()), start, end: addDays(start, 1), seconds: 0 });
    }
    return bins;
  }

  const first = range === "calendar" ? startOfMonth(now) : startOfDay(addDays(now, -29));
  const count = range === "calendar" ? daysBetween(first, addMonths(first, 1)) : 30;
  for (let i = 0; i < count; i++) {
    const start = addDays(first, i);
    bins.push({ label: String(start.getDate()), start, end: addDays(start, 1), seconds: 0 });
  }
  return bins;
}

function safeError(message) {
  const labels = labelFor(options.mode, options.range);
  return {
    ok: false,
    mode: options.mode,
    range: options.range,
    title: labels.title,
    primaryLabel: options.mode === "day" ? "0分钟" : "日均0分钟",
    comparisonLabel: `${labels.compare}持平`,
    totalSeconds: 0,
    averageSeconds: 0,
    afkSeconds: 0,
    currentApp: "",
    chart: makeBins(options.mode, options.range, makePeriod(options.mode, options.range)).map(b => ({ label: b.label, seconds: 0 })),
    apps: [],
    appListTitle: labels.apps,
    source: "activitywatch",
    watcher: "awatcher",
    error: message || "ActivityWatch summary unavailable",
    lastUpdated: localIso(new Date())
  };
}

function emit(result) {
  try {
    fs.mkdirSync(cacheDir, { recursive: true });
    const tmp = path.join(cacheDir, `.summary.json.${process.pid}.${Date.now()}`);
    fs.writeFileSync(tmp, JSON.stringify(result, null, 2));
    fs.renameSync(tmp, cacheFile);
  } catch (_) {
    // Cache failures should not leak internals or break stdout diagnostics.
  }
  process.stdout.write(JSON.stringify(result) + "\n");
}

function sanitizeApp(value) {
  if (value === undefined || value === null)
    return "unknown";
  let app = String(value).trim();
  if (!app)
    return "unknown";
  if (app.includes("/") || app.includes("\\"))
    app = app.split(/[\\/]/).filter(Boolean).pop() || "unknown";
  app = app.replace(/[\r\n\t]/g, " ").replace(/\s+/g, " ").trim();
  app = app.replace(/[^A-Za-z0-9._: -]/g, "");
  if (!app)
    return "unknown";
  return app.slice(0, 80);
}

function titleCaseApp(value) {
  return value
    .split(/[-_. ]+/)
    .filter(Boolean)
    .map(part => {
      const lower = part.toLowerCase();
      if (lower.length <= 2)
        return lower.toUpperCase();
      return lower.charAt(0).toUpperCase() + lower.slice(1);
    })
    .join(" ");
}

function displayNameForApp(value) {
  const raw = sanitizeApp(value);
  const key = raw.toLowerCase();
  if (friendlyAppNames.has(key))
    return friendlyAppNames.get(key);
  if (key.startsWith("org.") || key.startsWith("com.") || key.startsWith("io.") || key.startsWith("dev.")) {
    const parts = raw.split(".").filter(Boolean);
    const tail = parts[parts.length - 1] || raw;
    if (friendlyAppNames.has(tail.toLowerCase()))
      return friendlyAppNames.get(tail.toLowerCase());
    return titleCaseApp(tail).slice(0, 80);
  }
  return titleCaseApp(raw).slice(0, 80);
}

async function getJson(url) {
  const response = await fetch(url, { headers: { "Accept": "application/json" } });
  if (!response.ok)
    throw new Error("request failed");
  return await response.json();
}

function pickBucket(buckets, kind) {
  const host = os.hostname();
  const entries = Object.entries(buckets || {});
  const candidates = entries.filter(([id, meta]) => {
    const type = String(meta?.type || "");
    if (kind === "window")
      return id.startsWith("aw-watcher-window_") || type === "currentwindow";
    return id.startsWith("aw-watcher-afk_") || type === "afkstatus";
  });
  if (candidates.length === 0)
    return "";
  const exact = candidates.find(([id]) => id.endsWith(`_${host}`));
  return (exact || candidates[0])[0];
}

function eventStart(event) {
  const ts = new Date(event?.timestamp || 0);
  return Number.isNaN(ts.getTime()) ? null : ts;
}

function eventDuration(event) {
  const duration = Number(event?.duration || 0);
  return Number.isFinite(duration) && duration > 0 ? duration : 0;
}

function clippedInterval(event, rangeStart, rangeEnd) {
  const start = eventStart(event);
  if (!start)
    return null;
  const end = new Date(start.getTime() + eventDuration(event) * 1000);
  const clippedStart = new Date(Math.max(start.getTime(), rangeStart.getTime()));
  const clippedEnd = new Date(Math.min(end.getTime(), rangeEnd.getTime()));
  if (clippedEnd <= clippedStart)
    return null;
  return { start: clippedStart, end: clippedEnd };
}

function overlapSeconds(a, b) {
  const start = Math.max(a.start.getTime(), b.start.getTime());
  const end = Math.min(a.end.getTime(), b.end.getTime());
  return Math.max(0, (end - start) / 1000);
}

function activeOverlapSeconds(interval, targetInterval, notAfkIntervals) {
  const targetOverlap = overlapSeconds(interval, targetInterval);
  if (targetOverlap <= 0)
    return 0;
  if (notAfkIntervals.length === 0)
    return targetOverlap;
  const clipped = {
    start: new Date(Math.max(interval.start.getTime(), targetInterval.start.getTime())),
    end: new Date(Math.min(interval.end.getTime(), targetInterval.end.getTime()))
  };
  let total = 0;
  for (const active of notAfkIntervals)
    total += overlapSeconds(clipped, active);
  return total;
}

function eventApp(event) {
  const data = event?.data || {};
  return sanitizeApp(data.app || data.app_id || data.name || "unknown");
}

function addAppSeconds(target, app, seconds) {
  if (seconds <= 0)
    return;
  target[app] = (target[app] || 0) + seconds;
}

function sortedApps(secondsByApp, limit) {
  return Object.entries(secondsByApp)
    .map(([app, seconds]) => ({ app, displayName: displayNameForApp(app), seconds: Math.round(seconds) }))
    .filter(item => item.seconds > 0)
    .sort((a, b) => b.seconds - a.seconds || a.displayName.localeCompare(b.displayName))
    .slice(0, limit);
}

function formatDurationZh(seconds) {
  const total = Math.max(0, Math.round(Number(seconds || 0)));
  const hours = Math.floor(total / 3600);
  const minutes = Math.round((total % 3600) / 60);
  if (hours > 0 && minutes > 0)
    return `${hours}小时${minutes}分钟`;
  if (hours > 0)
    return `${hours}小时`;
  return `${minutes}分钟`;
}

function comparisonLabel(prefix, deltaSeconds) {
  const delta = Math.round(deltaSeconds);
  if (Math.abs(delta) < 60)
    return `${prefix}持平`;
  return `${prefix}${delta > 0 ? "增加" : "减少"}${formatDurationZh(Math.abs(delta))}`;
}

async function main() {
  const now = new Date();
  const labels = labelFor(options.mode, options.range);
  const period = makePeriod(options.mode, options.range, now);
  const chartBins = makeBins(options.mode, options.range, period, now);
  const queryStart = new Date(Math.min(period.start.getTime(), period.previousStart.getTime()));
  const queryEnd = period.end;

  let buckets;
  try {
    buckets = await getJson(`${baseUrl}/api/0/buckets/`);
  } catch (_) {
    emit(safeError("ActivityWatch server unavailable"));
    return;
  }

  const windowBucket = pickBucket(buckets, "window");
  const afkBucket = pickBucket(buckets, "afk");
  if (!windowBucket || !afkBucket) {
    emit(safeError("ActivityWatch window or AFK bucket missing"));
    return;
  }

  const query = `start=${encodeURIComponent(queryStart.toISOString())}&end=${encodeURIComponent(queryEnd.toISOString())}`;
  let windowEvents = [];
  let afkEvents = [];
  try {
    windowEvents = await getJson(`${baseUrl}/api/0/buckets/${encodeURIComponent(windowBucket)}/events?${query}`);
    afkEvents = await getJson(`${baseUrl}/api/0/buckets/${encodeURIComponent(afkBucket)}/events?${query}`);
  } catch (_) {
    emit(safeError("ActivityWatch event query failed"));
    return;
  }

  const currentInterval = { start: period.start, end: period.end };
  const previousInterval = { start: period.previousStart, end: period.previousEnd };
  const afkIntervals = [];
  const notAfkIntervals = [];

  for (const event of Array.isArray(afkEvents) ? afkEvents : []) {
    const interval = clippedInterval(event, queryStart, queryEnd);
    if (!interval)
      continue;
    const status = String(event?.data?.status || "").toLowerCase();
    if (status === "afk")
      afkIntervals.push(interval);
    else if (status === "not-afk")
      notAfkIntervals.push(interval);
  }

  let totalSeconds = 0;
  let previousSeconds = 0;
  let afkSeconds = 0;
  let latestWindow = null;
  let latestWindowTime = 0;
  const appSeconds = {};

  for (const afk of afkIntervals)
    afkSeconds += overlapSeconds(afk, currentInterval);

  for (const event of Array.isArray(windowEvents) ? windowEvents : []) {
    const interval = clippedInterval(event, queryStart, queryEnd);
    if (!interval)
      continue;

    const ts = eventStart(event)?.getTime() || 0;
    if (ts >= latestWindowTime && overlapSeconds(interval, currentInterval) > 0) {
      latestWindow = event;
      latestWindowTime = ts;
    }

    const currentSeconds = activeOverlapSeconds(interval, currentInterval, notAfkIntervals);
    const prevSeconds = activeOverlapSeconds(interval, previousInterval, notAfkIntervals);
    previousSeconds += prevSeconds;

    if (currentSeconds > 0) {
      totalSeconds += currentSeconds;
      addAppSeconds(appSeconds, eventApp(event), currentSeconds);
      for (const bin of chartBins)
        bin.seconds += activeOverlapSeconds(interval, bin, notAfkIntervals);
    }
  }

  const averageSeconds = options.mode === "day" ? totalSeconds : totalSeconds / period.denominator;
  const previousAverageSeconds = options.mode === "day" ? previousSeconds : previousSeconds / period.previousDenominator;
  const primaryLabel = options.mode === "day" ? formatDurationZh(totalSeconds) : `日均${formatDurationZh(averageSeconds)}`;

  emit({
    ok: true,
    mode: options.mode,
    range: options.range,
    title: labels.title,
    primaryLabel,
    comparisonLabel: comparisonLabel(labels.compare, averageSeconds - previousAverageSeconds),
    totalSeconds: Math.round(totalSeconds),
    averageSeconds: Math.round(averageSeconds),
    afkSeconds: Math.round(afkSeconds),
    currentApp: latestWindow ? displayNameForApp(eventApp(latestWindow)) : "",
    chart: chartBins.map(bin => ({ label: bin.label, seconds: Math.round(bin.seconds) })),
    apps: sortedApps(appSeconds, options.top),
    appListTitle: labels.apps,
    source: "activitywatch",
    watcher: "awatcher",
    lastUpdated: localIso(new Date())
  });
}

main().catch(() => emit(safeError("ActivityWatch summary failed")));
